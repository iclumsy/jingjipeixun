<view class="page">
  <view class="header-bg"></view>

  <view class="container">
    <view class="page-header">
      <view class="brand-row">
        <image class="brand-logo" src="/images/logo.png" mode="aspectFit"></image>
        <view>
          <view class="title">编辑学员信息</view>
          <view class="page-subtitle">修改完成后重新提交，将回到待审核</view>
        </view>
      </view>
    </view>

    <!-- 被驳回的提示 -->
    <view class="section-card reject-alert-card fade-enter" wx:if="{{status === 'rejected'}}">
      <view class="reject-alert-title">该记录已被驳回</view>
      <view wx:if="{{rejectReason}}" class="reject-alert-body">
        <text class="reject-alert-text">驳回原因：\n{{rejectReason}}</text>
      </view>
      <view class="reject-alert-desc">请根据驳回原因修改下方信息后重新提交</view>
    </view>

    <student-form
      trainingType="{{trainingType}}"
      formData="{{student}}"
      educationOptions="{{educationOptions}}"
      jobCategoryNames="{{jobCategoryNames}}"
      enabledAttachments="{{enabledAttachments}}"
      fieldErrors="{{fieldErrors}}"
      disableTrainingType="{{status === 'rejected'}}"
      showAgreement="{{true}}"
      agreementChecked="{{agreementChecked}}"
      showSubmit="{{true}}"
      submitText="更新信息"
      trainingCardTitle="培训类型"
      attachmentsTip="请上传清晰、完整的原件照片，避免反光和裁切。"
      bind:trainingtypechange="selectTrainingType"
      bind:genderchange="selectGender"
      bind:inputchange="onInputChange"
      bind:idcardblur="onIdCardBlur"
      bind:phoneblur="onPhoneBlur"
      bind:educationchange="onPickerChange"
      bind:jobcategorychange="onJobCategoryChange"
      bind:examprojectchange="onExamProjectChange"
      bind:fileuploaded="onFileUploaded"
      bind:filedeleted="onFileDeleted"
      bind:agreementchange="onAgreementChange"
      bind:openagreement="openUserAgreement"
      bind:openprivacy="openPrivacyPolicy"
      bind:submit="onTapSubmit"
    />
  </view>
</view>
