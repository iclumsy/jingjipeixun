<view class="page">
  <view class="header-bg"></view>

  <view wx:if="{{student}}" class="container">
    <view class="section-card summary-card fade-enter">
      <view class="summary-row">
        <view class="summary-title">审核详情</view>
        <view class="status-tag status-{{statusClass}}">{{statusText}}</view>
      </view>
      <view class="summary-meta">提交人：{{student.name || '-'}}</view>
      <view class="summary-meta">培训类型：{{trainingTypeText}}</view>
      <view class="summary-meta">公司：{{student.company || '-'}}</view>
      <view class="summary-meta">提交时间：{{submitTimeText}}</view>
      <view class="summary-meta" wx:if="{{student.reviewed_at}}">审核时间：{{reviewTimeText}}</view>
      <view wx:if="{{student.reject_reason}}" class="reject-reason-row">
        <text class="reject-label">驳回原因</text>
        <text class="reject-text">{{student.reject_reason}}</text>
      </view>
    </view>

    <admin-student-form
      trainingType="{{trainingType}}"
      applicationType="{{editStudent.application_type}}"
      formData="{{editStudent}}"
      educationOptions="{{educationOptions}}"
      jobCategoryNames="{{jobCategoryNames}}"
      enabledAttachments="{{enabledAttachments}}"
      fieldErrors="{{fieldErrors}}"
      showAgreement="{{false}}"
      showSubmit="{{false}}"
      trainingCardTitle="培训信息"
      attachmentsTip="可直接替换附件，未替换的附件会保留原记录。"
      bind:trainingtypechange="selectTrainingType"
      bind:applicationtypechange="selectApplicationType"
      bind:genderchange="selectGender"
      bind:inputchange="onInputChange"
      bind:idcardblur="onIdCardBlur"
      bind:phoneblur="onPhoneBlur"
      bind:educationchange="onEducationChange"
      bind:jobcategorychange="onJobCategoryChange"
      bind:examprojectchange="onExamProjectChange"
      bind:fileuploaded="onFileUploaded"
      bind:filedeleted="onFileDeleted"
      bind:swapmaterials="onSwapFromForm"
    />

    <view class="section-card materials-card fade-enter">
      <view class="card-header">
        <view>
          <view class="card-title">报名材料</view>
          <view class="card-subtitle">审核通过后系统自动生成，可预览并手工调整</view>
        </view>
      </view>

      <view class="materials-loading" wx:if="{{materialsLoading}}">报名材料加载中...</view>
      <view class="materials-empty" wx:elif="{{!generatedMaterialsExists}}">
        暂无报名材料，审核通过后系统会自动生成
      </view>
      <view class="materials-grid" wx:else>
        <view class="material-item {{item.fullWidth ? 'full-width' : ''}} {{item.isDownloadCard ? 'download-only' : ''}}" wx:for="{{generatedMaterials}}" wx:key="name">
          <view wx:if="{{item.isDownloadCard}}" class="material-download-card {{item.downloadCardTone}}" bindtap="previewGeneratedMaterial" data-index="{{index}}">
            <view class="material-download-icon">{{item.downloadIcon}}</view>
            <view class="material-download-title">{{item.title}}</view>
          </view>
          <view wx:else class="material-preview" bindtap="previewGeneratedMaterial" data-index="{{index}}">
            <image
              wx:if="{{item.previewUrl && !item.isDocument}}"
              class="material-image"
              src="{{item.previewUrl}}"
              mode="aspectFill"
            />
            <view wx:else class="material-doc">文件</view>
          </view>
          <view wx:if="{{!item.isDownloadCard}}" class="material-title">{{item.title}}</view>
          <view wx:if="{{item.adjusted}}" class="material-adjusted">已调整 {{item.adjusted_by}}</view>
          
          <!-- 常规预览型材料的操作 -->
          <view wx:if="{{!item.isDownloadCard}}" class="material-actions">
            <button class="material-btn" size="mini" bindtap="previewGeneratedMaterial" data-index="{{index}}">{{item.isDocument ? '下载' : '预览'}}</button>
            <button
              wx:if="{{item.adjustable}}"
              class="material-btn btn-adjust"
              size="mini"
              bindtap="openMaterialAdjust"
              data-index="{{index}}"
            >调整</button>
          </view>

          <!-- 下载型卡片的操作 (报名表、体检表) -->
          <view wx:else class="material-actions download-actions">
            <button class="material-btn" size="mini" bindtap="previewGeneratedMaterial" data-index="{{index}}">下载</button>
            <button
              wx:if="{{item.canRegenForm}}"
              class="material-btn btn-adjust"
              size="mini"
              bindtap="regenTrainingForm"
              data-index="{{index}}"
              loading="{{regenFormLoading}}"
              disabled="{{regenFormLoading}}"
            >重新生成</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="material-modal-mask" wx:if="{{materialModal.visible}}">
    <view class="material-modal">
      <view class="material-modal-head">
        <view>
          <view class="material-modal-title">{{materialModal.title}}</view>
          <view class="material-modal-sub">拖动裁剪框或角点，旋转角度会在确认后应用</view>
        </view>
        <view class="modal-close" bindtap="closeMaterialAdjust">×</view>
      </view>

      <view class="adjust-tabs" wx:if="{{materialModal.panels.length > 1}}">
        <view
          wx:for="{{materialModal.panels}}"
          wx:key="key"
          class="adjust-tab {{materialModal.activeKey === item.key ? 'active' : ''}}"
          bindtap="switchAdjustPanel"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>

      <view class="crop-stage-wrap">
        <view
          id="materialCropStage"
          class="crop-stage"
          catchtouchmove="onCropTouchMove"
          catchtouchend="onCropTouchEnd"
          catchtouchcancel="onCropTouchEnd"
        >
          <image
            wx:if="{{materialModal.activePanel && materialModal.activePanel.sourceUrl}}"
            class="crop-image"
            src="{{materialModal.activePanel.sourceUrl}}"
            mode="aspectFit"
            style="{{materialModal.activePanel.imageStyle}}"
          />
          <view
            wx:if="{{materialModal.activePanel && materialModal.activePanel.fixedRatio && materialModal.activePanel.frameStyle}}"
            class="crop-frame fixed-ratio"
            style="{{materialModal.activePanel.frameStyle}}"
            catchtouchstart="onCropFrameStart"
          >
            <view class="crop-frame-label">1寸比例</view>
          </view>
          <view
            wx:for="{{materialModal.activePanel.lines}}"
            wx:key="index"
            class="crop-line"
            style="{{item.style}}"
          ></view>
          <view
            wx:for="{{materialModal.activePanel.handles}}"
            wx:key="index"
            class="crop-handle"
            style="{{item.style}}"
            data-index="{{item.index}}"
            catchtouchstart="onCropHandleStart"
          >
            <view class="crop-handle-visual">
              <view class="crop-cross-h"></view>
              <view class="crop-cross-v"></view>
              <view class="crop-handle-number">{{item.text}}</view>
            </view>
          </view>
        </view>
        <view class="crop-status">
          当前旋转：{{materialModal.activePanel.rotation || 0}}°
        </view>
      </view>

      <view class="material-modal-actions">
        <view class="modal-tools-row">
          <button class="modal-tool-btn" data-direction="left" bindtap="rotateActivePanel">左转90°</button>
          <button class="modal-tool-btn spaced" data-direction="right" bindtap="rotateActivePanel">右转90°</button>
          <button class="modal-tool-btn spaced danger" bindtap="resetActivePanel">重置</button>
        </view>
        <view class="modal-confirm-row">
          <view class="white-bg-switch" wx:if="{{materialModal.materialType === 'photo'}}">
            <text class="white-bg-label">白底</text>
            <switch checked="{{materialModal.whiteBg !== false}}" bindchange="toggleWhiteBg" color="#4F46E5" style="zoom:0.7;" />
          </view>
          <button
            class="modal-confirm-btn"
            bindtap="confirmMaterialAdjust"
            loading="{{materialModal.submitting}}"
            disabled="{{materialModal.submitting}}"
          >确认调整</button>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-actions" wx:if="{{student}}">
    <button
      class="action-btn btn-save"
      bindtap="onSave"
      loading="{{saving}}"
      disabled="{{saving || actionLoading || loading}}"
    >保存</button>
    <button
      class="action-btn btn-approve {{!canReview ? 'disabled' : ''}}"
      bindtap="onApprove"
      loading="{{actionLoading && actionType === 'approve'}}"
      disabled="{{!canReview || saving || actionLoading || loading}}"
    >审核通过</button>
    <button
      class="action-btn btn-reject {{!canReview ? 'disabled' : ''}}"
      bindtap="onReject"
      loading="{{actionLoading && actionType === 'reject'}}"
      disabled="{{!canReview || saving || actionLoading || loading}}"
    >驳回</button>
  </view>


  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
