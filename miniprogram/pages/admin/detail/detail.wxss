@import "../../../styles/form-page.wxss";

.page {
  padding-bottom: 250rpx;
}

.container {
  padding-bottom: 330rpx;
}

.summary-card {
  margin-top: 4rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.summary-meta {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #6b7c93;
  line-height: 1.55;
}

.status-tag {
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-unreviewed {
  background: #fff6df;
  color: #9a5600;
}

.status-reviewed {
  background: #eaf9ef;
  color: #15803d;
}

.status-rejected {
  background: #ffeceb;
  color: #b42318;
}

.bottom-actions {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: calc(10rpx + env(safe-area-inset-bottom));
  bottom: calc(10rpx + constant(safe-area-inset-bottom));
  z-index: 50;
  display: flex;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  align-items: center;
  padding: 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dce6f2;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 32rpx rgba(19, 37, 69, 0.16);
  box-sizing: border-box;
}

.action-btn {
  margin: 0;
  width: 100%;
  height: 72rpx;
  min-width: 0;
  border-radius: 12rpx;
  border: none;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  padding: 0 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.action-btn::after {
  border: none;
}

.btn-save {
  background: #e9efff;
  color: #1d4ed8;
}

.btn-approve {
  background: #eaf9ef;
  color: #15803d;
}

.btn-reject {
  background: #ffeceb;
  color: #b42318;
}

.btn-download {
  background: #f0ebff;
  color: #6d28d9;
}

.action-btn.disabled {
  opacity: 0.45;
}

.readonly-hint {
  margin: 0 24rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #edf4ff;
  color: #1d4ed8;
  font-size: 22rpx;
  line-height: 1.45;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
  color: #9aa8bc;
  font-size: 24rpx;
}

.card-activated-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.card-activated-tag {
  font-size: 22rpx;
  font-weight: 600;
  color: #15803d;
  background: #dcfce7;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.card-query-btn {
  font-size: 22rpx !important;
  color: #0369a1 !important;
  background: #f0f9ff !important;
  border: 1rpx solid #bae6fd !important;
  padding: 4rpx 16rpx !important;
  border-radius: 12rpx !important;
  line-height: 1.6 !important;
  min-height: 0 !important;
  height: auto !important;
}

.reject-reason-row {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  background: #fff5f5;
  border: 1rpx solid #fed7d7;
  border-radius: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.reject-label {
  flex: 0 0 auto;
  font-size: 22rpx;
  color: #c53030;
  font-weight: 600;
  line-height: 1.5;
}

.reject-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #9b2c2c;
  line-height: 1.5;
  word-break: break-all;
}

.materials-card {
  margin-bottom: 18rpx;
}

.card-subtitle {
  margin-top: 6rpx;
  color: #7b8ca3;
  font-size: 22rpx;
  line-height: 1.45;
}

.materials-loading,
.materials-empty {
  padding: 28rpx 0 8rpx;
  color: #8a9ab0;
  font-size: 23rpx;
  line-height: 1.5;
}

.materials-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.material-item {
  min-width: 0;
  padding: 12rpx;
  border: 1rpx solid #dce6f2;
  border-radius: 12rpx;
  background: #f8fbff;
  box-sizing: border-box;
}

.material-item.full-width {
  grid-column: 1 / -1;
}

.material-preview {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background: #edf2f7;
  border: 1rpx solid #e2e8f0;
}

.material-image {
  width: 100%;
  height: 100%;
  display: block;
}

.material-doc {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 24rpx;
  background: #f8fafc;
}

.material-title {
  margin-top: 10rpx;
  color: #1f2937;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.material-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.material-btn {
  flex: 1;
  height: 54rpx;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #475569;
  font-size: 21rpx;
  line-height: 54rpx;
}

.material-btn::after {
  border: none;
}

.material-btn.primary {
  background: #e9efff;
  border-color: #bdd0ff;
  color: #1d4ed8;
  font-weight: 700;
}

.material-modal-mask {
  position: fixed;
  z-index: 200;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  display: flex;
  align-items: stretch;
  justify-content: center;
}

.material-modal {
  width: 100%;
  min-height: 100%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
  box-sizing: border-box;
}

.material-modal-head {
  padding: 28rpx 26rpx 18rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
  border-bottom: 1rpx solid #e2e8f0;
}

.material-modal-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.3;
}

.material-modal-sub {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.45;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  color: #64748b;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  line-height: 1;
}

.adjust-tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 0;
}

.adjust-tab {
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 10rpx;
  border: 1rpx solid #d6e0ed;
  color: #475569;
  background: #ffffff;
  font-size: 23rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.adjust-tab.active {
  background: #1d4ed8;
  border-color: #1d4ed8;
  color: #ffffff;
  font-weight: 700;
}

.crop-stage-wrap {
  flex: 1;
  min-height: 0;
  padding: 18rpx 20rpx 0;
  display: flex;
  flex-direction: column;
}

.crop-stage {
  position: relative;
  flex: 1;
  min-height: 620rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #141826;
  border: 1rpx solid #2b3246;
}

.crop-image {
  position: absolute;
  display: block;
  transform-origin: center center;
}

.crop-frame {
  position: absolute;
  border: 3rpx solid #2f6af5;
  box-sizing: border-box;
  background: rgba(47, 106, 245, 0.08);
}

.crop-line {
  position: absolute;
  height: 4rpx;
  background: #2f6af5;
  transform-origin: 0 50%;
  pointer-events: none;
  box-shadow: 0 0 0 1rpx rgba(255, 255, 255, 0.6);
}

.crop-frame-label {
  position: absolute;
  left: 8rpx;
  top: -34rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 6rpx;
  background: rgba(47, 106, 245, 0.92);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
}

.crop-handle {
  position: absolute;
  width: 42rpx;
  height: 42rpx;
  margin-left: -21rpx;
  margin-top: -21rpx;
  border-radius: 50%;
  border: 3rpx solid #2f6af5;
  background: #ffffff;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 38rpx;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.25);
}

.crop-status {
  height: 54rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 54rpx;
}

.material-modal-actions {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 24rpx 24rpx;
  border-top: 1rpx solid #e2e8f0;
  background: #ffffff;
}

.modal-tools-row {
  display: flex;
  align-items: center;
}

.white-bg-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.white-bg-label {
  font-size: 22rpx;
  color: #334155;
  font-weight: 600;
  white-space: nowrap;
}

.modal-confirm-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-tool-btn,
.modal-confirm-btn {
  height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  border: none;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 52rpx;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  min-width: 0;
}

.modal-tool-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  color: #1d4ed8;
  box-shadow: inset 0 0 0 1rpx #dce7f5;
}

.modal-tool-btn.spaced {
  margin-left: 18rpx;
}

.modal-tool-btn.danger {
  background: rgba(255, 238, 238, 0.95);
  color: #b42318;
  box-shadow: none;
}

.modal-confirm-btn {
  flex: 1;
  border: none;
  background: #4F46E5;
  color: #ffffff;
  font-weight: 700;
}

.modal-tool-btn::after,
.modal-confirm-btn::after {
  border: none;
}
