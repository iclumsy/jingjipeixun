<view class="page">
  <view class="container">
    <view class="top-card card fade-enter">
      <view class="top-row">
        <view class="top-title">审核管理</view>
        <view class="top-count">当前 {{records.length}} 条</view>
      </view>
      <view class="top-desc">支持按状态、培训类型、公司筛选；可直接通过、驳回或删除记录。</view>
    </view>

    <view class="filter-card card fade-enter">
      <view class="filter-row">
        <view class="filter-title">类型</view>
        <view class="chip-list">
          <view
            wx:for="{{trainingTypeFilters}}"
            wx:key="value"
            class="filter-chip {{filters.training_type === item.value ? 'active' : ''}}"
            bindtap="onTrainingTypeFilterTap"
            data-value="{{item.value}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-row">
        <view class="filter-title">状态</view>
        <view class="chip-list">
          <view
            wx:for="{{statusFilters}}"
            wx:key="value"
            class="filter-chip {{filters.status === item.value ? 'active' : ''}}"
            bindtap="onStatusFilterTap"
            data-value="{{item.value}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-row">
        <view class="filter-title">公司</view>
        <view class="company-picker">
          <picker mode="selector" range="{{companyOptions}}" value="{{companyIndex}}" bindchange="onCompanyChange">
            <view class="picker-value">{{companyOptions[companyIndex] || '全部'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="record-list">
      <view
        wx:for="{{records}}"
        wx:key="_id"
        class="record-card tap-feedback fade-enter"
        bindtap="openDetail"
        data-id="{{item._id}}"
      >
        <view class="card-head">
          <view class="name-wrap">
            <view class="student-name">{{item.name || '-'}}</view>
            <view class="time-text">{{item.submitTimeText}}</view>
          </view>
          <view class="status-badge badge-{{item.status}}">{{item.statusText}}</view>
        </view>

        <view class="meta-row">
          <text wx:if="{{item.training_type === 'special_equipment' && item.application_type === 'renewal'}}" class="meta-chip" style="color:#e65100;background:#fff3e0;">复审</text>
          <text class="meta-chip">{{item.job_category || '-'}}</text>
          <text wx:if="{{item.exam_project}}" class="meta-chip">{{item.exam_project}}</text>
          <text
            wx:if="{{item.status === 'reviewed' && item.training_type === 'special_equipment' && item.card_activated}}"
            class="meta-chip card-query-chip"
            catchtap="onQueryCardTap"
            data-id="{{item._id}}"
          >🔍 学习卡信息</text>
          <text
            wx:if="{{item.status === 'reviewed' && item.training_type === 'special_equipment' && !item.card_activated}}"
            class="meta-chip card-activate-chip"
            catchtap="onActivateCardTap"
            data-id="{{item._id}}"
            data-name="{{item.name}}"
            data-phone="{{item.phone}}"
            data-id-card="{{item.id_card}}"
            data-exam-project="{{item.exam_project || item.job_category}}"
          >🎓 开学习卡</text>
        </view>

        <view class="detail-with-form">
          <view class="detail-list">
            <view class="detail-line">
              <text class="detail-label">单位</text>
              <text class="detail-value">{{item.company || '-'}}</text>
            </view>
            <view class="detail-line">
              <text class="detail-label">证件</text>
              <text class="detail-value">{{item.id_card || '-'}}</text>
            </view>
            <view class="detail-line">
              <text class="detail-label">手机</text>
              <text class="detail-value">{{item.phone || '-'}}</text>
            </view>
          </view>
          <view
            wx:if="{{item.status === 'registered'}}"
            class="form-side-btn"
            catchtap="onDownloadRegFormTap"
            data-id="{{item._id}}"
            data-name="{{item.name}}"
            data-id-card="{{item.id_card}}"
            data-status="{{item.status}}"
          >
            <text class="form-side-emoji">📄</text>
            <text class="form-side-label">报名表</text>
          </view>
          <view
            wx:if="{{item.trainingFormUrl}}"
            class="form-side-btn"
            catchtap="onDownloadTrainingFormTap"
            data-id="{{item._id}}"
            data-name="{{item.name}}"
            data-id-card="{{item.id_card}}"
          >
            <text class="form-side-emoji">📄</text>
            <text class="form-side-label">体检表</text>
          </view>
        </view>

        <view wx:if="{{item.status === 'rejected' && item.reject_reason}}" class="reject-reason-row">
          <text class="reject-label">驳回原因</text>
          <text class="reject-text">{{item.reject_reason}}</text>
        </view>

        <view class="record-actions">
          <button
            wx:if="{{item.status === 'unreviewed'}}"
            class="action-btn btn-approve"
            size="mini"
            catchtap="onApproveTap"
            data-id="{{item._id}}"
            data-status="{{item.status}}"
          >✅ 审核通过</button>

          <button
            class="action-btn btn-reject {{(item.status === 'registered') ? 'disabled' : ''}}"
            size="mini"
            catchtap="onRejectTap"
            data-id="{{item._id}}"
            data-status="{{item.status}}"
            disabled="{{item.status === 'registered'}}"
          >↩️ 驳回</button>

          <button
            class="action-btn btn-delete"
            size="mini"
            catchtap="onDeleteTap"
            data-id="{{item._id}}"
          >🗑️ 删除</button>

          <button
            wx:if="{{item.status === 'reviewed' || item.status === 'registered'}}"
            class="action-btn btn-secondary {{item.status === 'registered' ? 'disabled' : ''}}"
            size="mini"
            catchtap="onSubmitRegisterTap"
            data-id="{{item._id}}"
            disabled="{{item.status === 'registered'}}"
          >🚀 提交报名</button>
        </view>
      </view>

      <view class="loading" wx:if="{{loading && !refreshing}}">加载中...</view>
      <view class="no-more" wx:if="{{!loading && !hasMore && records.length > 0}}">已显示全部记录</view>

      <view class="state-wrap" wx:if="{{!loading && records.length === 0}}">
        <view class="state-dot"></view>
        <view class="state-title">暂无符合条件的记录</view>
        <view class="state-desc">可切换筛选项或下拉刷新后重试</view>
      </view>
    </view>
  </view>

  <!-- 自定义开卡确认弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showActivateModal}}" catchtap="closeActivateModal">
    <view class="custom-modal-box" catchtap="preventD">
      <view class="activate-modal-header">
        <view class="activate-modal-title">🎓 开学习卡确认</view>
        <view class="activate-modal-sub">请核对以下学员信息后操作</view>
      </view>
      <view class="activate-modal-body">
        <view class="activate-info-grid">
          <text class="grid-label">姓名</text>
          <text class="grid-value grid-name">{{activateStudent.name || '-'}}</text>
          <text class="grid-label">手机号</text>
          <text class="grid-value grid-phone">{{activateStudent.phone || '-'}}</text>
          <text class="grid-label">身份证</text>
          <text class="grid-value grid-id">{{activateStudent.idCard || '-'}}</text>
          <text class="grid-label">培训项目</text>
          <text class="grid-value grid-project">{{activateStudent.examProject || '-'}}</text>
        </view>
        <view class="activate-warning">
          <text class="warning-icon">⚠️</text>
          <text class="warning-text">确认后该学员信息将被提交至培训考试系统，请确保信息无误。</text>
        </view>
      </view>
      <view class="activate-modal-footer">
        <button class="activate-btn-cancel" catchtap="closeActivateModal">取消</button>
        <button class="activate-btn-confirm" catchtap="confirmActivateCard" disabled="{{activating}}">{{activating ? '开卡中...' : '确认开卡'}}</button>
      </view>
    </view>
  </view>

  <!-- 学习卡信息查询弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showCardInfoModal}}" catchtap="closeCardInfoModal">
    <view class="card-info-modal" catchtap="preventD">
      <view class="card-info-header">
        <text class="card-info-icon">🎓</text>
        <view class="card-info-header-text">
          <text class="card-info-title">学习卡信息</text>
          <text class="card-info-sub">君瑞培训系统查询结果</text>
        </view>
        <text class="card-info-state {{cardInfo.state === '有效' ? 'state-valid' : 'state-other'}}">{{cardInfo.state || '-'}}</text>
      </view>
      <view class="card-info-body">
        <view class="card-info-section-title">个人信息</view>
        <view class="card-info-grid">
          <view class="card-info-item">
            <text class="card-info-label">姓名</text>
            <text class="card-info-value bold">{{cardInfo.name || '-'}}</text>
          </view>
          <view class="card-info-item">
            <text class="card-info-label">性别</text>
            <text class="card-info-value bold">{{cardInfo.sex || '-'}}</text>
          </view>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">身份证号</text>
          <text class="card-info-value mono">{{cardInfo.id_card || '-'}}</text>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">手机号</text>
          <text class="card-info-value">{{cardInfo.phone || '-'}}</text>
        </view>
        <view class="card-info-divider"></view>
        <view class="card-info-section-title">培训信息</view>
        <view class="card-info-full">
          <text class="card-info-label">考试项目</text>
          <text class="card-info-value">{{cardInfo.project_name || '-'}}</text>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">开卡时间</text>
          <text class="card-info-value">{{cardInfo.card_time || '-'}}</text>
        </view>
        <view class="card-info-divider"></view>
        <view class="card-info-section-title">学习卡</view>
        <view class="card-info-card-box">
          <view class="card-info-card-item">
            <text class="card-info-card-label">卡号</text>
            <text class="card-info-card-value">{{cardInfo.card_id || '-'}}</text>
          </view>
          <view class="card-info-card-sep"></view>
          <view class="card-info-card-item right">
            <text class="card-info-card-label">密码</text>
            <text class="card-info-card-value">{{cardInfo.card_pwd || '-'}}</text>
          </view>
        </view>
      </view>
      <view class="card-info-footer">
        <button class="card-info-close-btn" catchtap="closeCardInfoModal">关 闭</button>
      </view>
    </view>
  </view>

</view>
