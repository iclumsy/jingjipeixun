<view class="page">
  <view class="container">
    <!-- 顶部选项卡 -->
    <view class="segment-tabs card fade-enter">
      <view class="segment-tab {{currentTab === 'review' ? 'active' : ''}}" bindtap="switchSegmentTab" data-tab="review">学员管理</view>
      <view class="segment-tab {{currentTab === 'report' ? 'active' : ''}}" bindtap="switchSegmentTab" data-tab="report">学习统计</view>
    </view>

    <!-- 选项 1: 信息审核视图 -->
    <block wx:if="{{currentTab === 'review'}}">
      <view class="filter-card card fade-enter">
        <view class="filter-row" wx:if="{{false}}">
          <view class="filter-title">类型</view>
          <view class="chip-list">
            <view
              wx:for="{{trainingTypeFilters}}"
              wx:key="value"
              class="filter-chip {{filters.training_type === item.value ? 'active' : ''}}"
              bindtap="onTrainingTypeFilterTap"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-row">
          <view class="filter-title">状态</view>
          <view class="chip-list">
            <view
              wx:for="{{statusFilters}}"
              wx:key="value"
              class="filter-chip {{filters.status === item.value ? 'active' : ''}}"
              bindtap="onStatusFilterTap"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-row" wx:if="{{false}}">
          <view class="filter-title">公司</view>
          <view class="company-picker">
            <picker mode="selector" range="{{companyOptions}}" value="{{companyIndex}}" bindchange="onCompanyChange">
              <view class="picker-value">{{companyOptions[companyIndex] || '全部'}}</view>
            </picker>
          </view>
        </view>
      </view>

      <view class="record-list">
        <view
          wx:for="{{records}}"
          wx:key="_id"
          class="record-card tap-feedback fade-enter"
          bindtap="openDetail"
          data-id="{{item._id}}"
        >
          <view class="card-head">
            <view class="name-wrap">
              <view class="student-name">{{item.name || '-'}}</view>
              <view class="time-text">{{item.submitTimeText}}</view>
            </view>
            <view class="card-head-actions">
              <view
                wx:if="{{item.canViewLearningStatus}}"
                class="learning-status-chip"
                catchtap="onLearningStatusTap"
                data-id="{{item._id}}"
              >学习情况</view>
              <view class="status-badge badge-{{item.statusClass}}">{{item.statusText}}</view>
            </view>
          </view>

          <view class="meta-row">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="text" class="meta-chip" style="color:{{tag.color}};background:{{tag.bg}};">{{tag.text}}</text>
            <text class="meta-chip">{{item.job_category || '-'}}</text>
            <text wx:if="{{item.exam_project}}" class="meta-chip">{{item.exam_project}}</text>
            <text
              wx:if="{{item.actions.canQueryCard}}"
              class="meta-chip card-query-chip"
              catchtap="onQueryCardTap"
              data-id="{{item._id}}"
            >🔍 学习卡信息</text>
            <text
              wx:if="{{item.actions.canActivateCard}}"
              class="meta-chip card-activate-chip"
              catchtap="onActivateCardTap"
              data-id="{{item._id}}"
              data-name="{{item.name}}"
              data-phone="{{item.phone}}"
              data-id-card="{{item.id_card}}"
              data-exam-project="{{item.exam_project || item.job_category}}"
            >🎓 开学习卡</text>
          </view>

          <view class="detail-with-form">
            <view class="detail-list">
              <view class="detail-line">
                <text class="detail-label">单位</text>
                <text class="detail-value">{{item.company || '-'}}</text>
              </view>
              <view class="detail-line">
                <text class="detail-label">证件</text>
                <text class="detail-value">{{item.id_card || '-'}}</text>
              </view>
              <view class="detail-line">
                <text class="detail-label">手机</text>
                <text class="detail-value">{{item.phone || '-'}}</text>
              </view>
            </view>
            <view class="side-buttons-wrap" style="display:flex;gap:12rpx;flex-shrink:0;">
              <view
                wx:if="{{item.actions.canDownloadRegForm}}"
                class="form-side-btn btn-form-reg"
                catchtap="onDownloadRegFormTap"
                data-id="{{item._id}}"
                data-name="{{item.name}}"
                data-id-card="{{item.id_card}}"
              >
                <text class="form-side-emoji">✏️</text>
                <text class="form-side-label">报名表</text>
              </view>
              <view
                wx:if="{{item.actions.canDownloadHealthForm}}"
                class="form-side-btn btn-form-health"
                catchtap="onDownloadTrainingFormTap"
                data-id="{{item._id}}"
                data-name="{{item.name}}"
                data-id-card="{{item.id_card}}"
              >
                <text class="form-side-emoji">📄</text>
                <text class="form-side-label">体检表</text>
              </view>
            </view>
          </view>

          <view wx:if="{{item.reject_reason}}" class="reject-reason-row">
            <text class="reject-label">驳回原因</text>
            <text class="reject-text">{{item.reject_reason}}</text>
          </view>

          <view class="record-actions actions-status-{{item.status}}">
            <!-- 待审核 -->
            <block wx:if="{{item.status === 'unreviewed'}}">
              <button
                wx:if="{{item.actions.canApprove}}"
                class="action-btn btn-approve"
                size="mini"
                catchtap="onApproveTap"
                data-id="{{item._id}}"
              >✅ 审核通过</button>

              <button
                wx:if="{{item.actions.canReject}}"
                class="action-btn btn-reject"
                size="mini"
                catchtap="onRejectTap"
                data-id="{{item._id}}"
              >↩️ 驳回</button>

              <button
                class="action-btn btn-operation-log"
                size="mini"
                catchtap="onOperationLogTap"
                data-id="{{item._id}}"
              >📋 操作记录</button>
            </block>
            <!-- 已通过：主操作 + 操作记录 + 更多操作 -->
            <block wx:elif="{{item.status === 'reviewed'}}">
              <button
                wx:if="{{item.actions.canSubmitReg}}"
                class="action-btn btn-secondary"
                size="mini"
                catchtap="onSubmitRegisterTap"
                data-id="{{item._id}}"
              >🚀 提交报名</button>

              <button
                class="action-btn btn-operation-log"
                size="mini"
                catchtap="onOperationLogTap"
                data-id="{{item._id}}"
              >📋 操作记录</button>

              <button
                class="action-btn btn-more"
                size="mini"
                catchtap="onMoreActionsTap"
                data-id="{{item._id}}"
              >⋯ 更多操作</button>
            </block>

            <!-- 已报名：仅保留可执行项 -->
            <block wx:elif="{{item.status === 'registered'}}">
              <button
                class="action-btn btn-operation-log"
                size="mini"
                catchtap="onOperationLogTap"
                data-id="{{item._id}}"
              >📋 操作记录</button>
            </block>

            <!-- 已驳回（默认） -->
            <block wx:else>
              <button
                wx:if="{{item.actions.canReject}}"
                class="action-btn btn-reject"
                size="mini"
                catchtap="onRejectTap"
                data-id="{{item._id}}"
              >↩️ 驳回</button>

              <button
                class="action-btn btn-operation-log"
                size="mini"
                catchtap="onOperationLogTap"
                data-id="{{item._id}}"
              >📋 操作记录</button>
            </block>
          </view>
        </view>

        <view class="loading" wx:if="{{loading && !refreshing}}">加载中...</view>
        <view class="no-more" wx:if="{{!loading && !hasMore && records.length > 0}}">已显示全部记录</view>

        <view class="state-wrap" wx:if="{{!loading && records.length === 0}}">
          <view class="state-dot"></view>
          <view class="state-title">暂无符合条件的记录</view>
          <view class="state-desc">可切换筛选项或下拉刷新后重试</view>
        </view>
      </view>
    </block>

    <!-- 选项 2: 学习统计视图 -->
    <block wx:if="{{currentTab === 'report'}}">
      <view class="report-filter-card card fade-enter">
        <!-- 搜索框 -->
        <view class="search-bar">
          <icon class="search-icon" type="search" size="16" color="#999999"></icon>
          <input 
            class="search-input" 
            type="text" 
            placeholder="搜索姓名、电话或科目代号..." 
            value="{{searchQuery}}" 
            bindinput="onReportSearchInput"
            bindconfirm="onReportSearchConfirm" 
            confirm-type="search"
          />
          <view class="search-clear" wx:if="{{searchQuery}}" bindtap="onReportSearchClear">
            <icon type="clear" size="16" color="#cccccc"></icon>
          </view>
          <view class="search-btn" bindtap="onReportSearchConfirm">搜索</view>
        </view>

        <!-- 状态过滤 Tab -->
        <view class="filter-tabs">
          <view 
            wx:for="{{statusTabs}}" 
            wx:key="value" 
            class="tab-item {{activeStatus === item.value ? 'active' : ''}}" 
            bindtap="onReportStatusTabTap" 
            data-val="{{item.value}}"
          >
            <text class="tab-text">{{item.label}}</text>
            <view class="tab-indicator" wx:if="{{activeStatus === item.value}}"></view>
          </view>
        </view>
      </view>

      <view class="student-list" wx:if="{{reportList.length > 0}}">
        <view 
          wx:for="{{reportList}}" 
          wx:key="index" 
          class="student-card report-flat-card tap-feedback"
          bindtap="onLearningStatusTap"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
        >
          <view class="card-main">
            <!-- 第一行：基础身份 + 报考科目 (左侧) + 最近学习时间 + 项目状态 (靠右) -->
            <view class="card-row-first">
              <view class="first-left">
                <text class="std-name">{{item.name}}</text>
                <text class="std-project">{{item.examProject}}<text class="std-code" wx:if="{{item.projectCode}}">({{item.projectCode}})</text></text>
              </view>
              <view class="first-right">
                <text class="std-time">📅 {{item.lastStudyTimeText}}</text>
                <view class="status-badge status-{{item.state}}">{{item.stateText}}</view>
              </view>
            </view>
            
            <!-- 胶囊进度条：绿色代表已掌握，蓝色代表已做但未掌握 -->
            <view class="progress-capsule">
              <view class="capsule-fill mastered" style="width: {{item.masteredPercent}}%;"></view>
              <view class="capsule-fill practicing" style="width: {{(item.progressPercent - item.masteredPercent) > 0 ? (item.progressPercent - item.masteredPercent) : 0}}%;"></view>
            </view>
            
            <!-- 第二行：数据指标列网格 (3列等分对齐) -->
            <view class="card-row-second chip-grid-cols">
              <view class="data-chip progress-chip">
                <text class="chip-icon">📊</text>
                <text class="chip-val">{{item.doneCount}}/{{item.questionCount}} ({{item.masteredPercent}}%)</text>
              </view>
              <view class="data-chip exam-chip {{item.examCount > 0 ? 'has-exam' : ''}}">
                <text class="chip-icon">🏆</text>
                <text class="chip-val">{{item.examCount}}次{{item.bestScore !== null ? ' (' + item.bestScore + '分)' : ''}}</text>
              </view>
              <view class="data-chip duration-chip">
                <text class="chip-icon">⏱️</text>
                <text class="chip-val">{{item.studyDurationText}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 加载更多 / 到底提示 -->
        <view class="load-more-tip">
          <text wx:if="{{reportLoading}}">正在加载...</text>
          <text wx:elif="{{!reportHasMore && reportList.length > 0}}">已显示全部学习记录</text>
        </view>
      </view>

      <!-- 暂无学员占位 -->
      <view class="empty-state" wx:elif="{{reportInitialized && reportList.length === 0}}">
        <view class="empty-icon">📂</view>
        <view class="empty-text">暂无符合条件的学员学习记录</view>
      </view>
    </block>
  </view>

  <!-- 自定义开卡确认弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showActivateModal}}" catchtap="closeActivateModal">
    <view class="custom-modal-box" catchtap="preventD">
      <view class="activate-modal-header">
        <view class="activate-modal-title">🎓 开学习卡确认</view>
        <view class="activate-modal-sub">请核对以下学员信息后操作</view>
      </view>
      <view class="activate-modal-body">
        <view class="activate-info-grid">
          <text class="grid-label">姓名</text>
          <text class="grid-value grid-name">{{activateStudent.name || '-'}}</text>
          <text class="grid-label">手机号</text>
          <text class="grid-value grid-phone">{{activateStudent.phone || '-'}}</text>
          <text class="grid-label">身份证</text>
          <text class="grid-value grid-id">{{activateStudent.idCard || '-'}}</text>
          <text class="grid-label">培训项目</text>
          <text class="grid-value grid-project">{{activateStudent.examProject || '-'}}</text>
        </view>
        <view class="activate-warning">
          <text class="warning-icon">⚠️</text>
          <text class="warning-text">确认后该学员信息将被提交至培训考试系统，请确保信息无误。</text>
        </view>
      </view>
      <view class="activate-modal-footer">
        <button class="activate-btn-cancel" catchtap="closeActivateModal">取消</button>
        <button class="activate-btn-confirm" catchtap="confirmActivateCard" disabled="{{activating}}">{{activating ? '开卡中...' : '确认开卡'}}</button>
      </view>
    </view>
  </view>

  <!-- 提交报名确认弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showSubmitModal}}" catchtap="closeSubmitModal">
    <view class="custom-modal-box" catchtap="preventD">
      <view class="activate-modal-header" style="background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);">
        <view class="activate-modal-title">📤 提交报名确认</view>
        <view class="activate-modal-sub">需保送至省网平台的数据如下，请确认是否真实无误</view>
      </view>
      <view class="activate-modal-body">
        <view class="activate-info-grid">
          <text class="grid-label">姓名</text>
          <text class="grid-value grid-name">{{submitStudent.name || '-'}}</text>
          <text class="grid-label">性别</text>
          <text class="grid-value">{{submitStudent.gender || '-'}}</text>
          <text class="grid-label">手机号</text>
          <text class="grid-value grid-phone">{{submitStudent.phone || '-'}}</text>
          <text class="grid-label">身份证</text>
          <text class="grid-value grid-id">{{submitStudent.id_card || '-'}}</text>
          <text class="grid-label">学历</text>
          <text class="grid-value">{{submitStudent.education || '-'}}</text>
          <text class="grid-label">工作单位</text>
          <text class="grid-value" style="font-size:24rpx;line-height:1.2;align-self:center;">{{submitStudent.company || '-'}}</text>
          <text class="grid-label">单位地址</text>
          <text class="grid-value" style="font-size:24rpx;line-height:1.2;align-self:center;">{{submitStudent.company_address || '-'}}</text>
          <text class="grid-label">作业类别</text>
          <text class="grid-value">{{submitStudent._tp_job_category || submitStudent.job_category || '-'}}</text>
          <text class="grid-label">报考项目</text>
          <text class="grid-value grid-project">{{submitStudent._tp_exam_project || submitStudent.exam_project || '-'}}</text>
        </view>
        <view class="activate-warning" style="background: #FFF7ED; color: #EA580C; border-left: 6rpx solid #F97316;">
          <text class="warning-icon">⚠️</text>
          <text class="warning-text">核对无误后进行推送并生成流水号，如信息有误需退网走人工补单！</text>
        </view>
      </view>
      <view class="activate-modal-footer">
        <button class="activate-btn-cancel" catchtap="closeSubmitModal">取消</button>
        <button class="activate-btn-confirm" style="background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); box-shadow: 0 6rpx 16rpx rgba(217, 119, 6, 0.35);" catchtap="confirmSubmitRegister" disabled="{{submitting}}">{{submitting ? '通信中...' : '确定上报'}}</button>
      </view>
    </view>
  </view>

  <!-- 学习卡信息查询弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showCardInfoModal}}" catchtap="closeCardInfoModal">
    <view class="card-info-modal" catchtap="preventD">
      <view class="card-info-header">
        <text class="card-info-icon">🎓</text>
        <view class="card-info-header-text">
          <text class="card-info-title">学习卡信息</text>
          <text class="card-info-sub">君瑞培训系统查询结果</text>
        </view>
        <text class="card-info-state {{cardInfo.state === '有效' ? 'state-valid' : 'state-other'}}">{{cardInfo.state || '-'}}</text>
      </view>
      <view class="card-info-body">
        <view class="card-info-section-title">个人信息</view>
        <view class="card-info-grid">
          <view class="card-info-item">
            <text class="card-info-label">姓名</text>
            <text class="card-info-value bold">{{cardInfo.name || '-'}}</text>
          </view>
          <view class="card-info-item">
            <text class="card-info-label">性别</text>
            <text class="card-info-value bold">{{cardInfo.sex || '-'}}</text>
          </view>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">身份证号</text>
          <text class="card-info-value mono">{{cardInfo.id_card || '-'}}</text>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">手机号</text>
          <text class="card-info-value">{{cardInfo.phone || '-'}}</text>
        </view>
        <view class="card-info-divider"></view>
        <view class="card-info-section-title">培训信息</view>
        <view class="card-info-full">
          <text class="card-info-label">考试项目</text>
          <text class="card-info-value">{{cardInfo.project_name || '-'}}</text>
        </view>
        <view class="card-info-full">
          <text class="card-info-label">开卡时间</text>
          <text class="card-info-value">{{cardInfo.card_time || '-'}}</text>
        </view>
        <view class="card-info-divider"></view>
        <view class="card-info-section-title">学习卡</view>
        <view class="card-info-card-box">
          <view class="card-info-card-item">
            <text class="card-info-card-label">卡号</text>
            <text class="card-info-card-value">{{cardInfo.card_id || '-'}}</text>
          </view>
          <view class="card-info-card-sep"></view>
          <view class="card-info-card-item right">
            <text class="card-info-card-label">密码</text>
            <text class="card-info-card-value">{{cardInfo.card_pwd || '-'}}</text>
          </view>
        </view>
      </view>
      <view class="card-info-footer">
        <button class="card-info-close-btn" catchtap="closeCardInfoModal">关 闭</button>
      </view>
    </view>
  </view>

  <!-- 学习情况弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showLearningStatusModal}}" catchtap="closeLearningStatusModal">
    <view class="learning-modal" catchtap="preventD">
      <view class="learning-modal-header">
        <view class="learning-modal-heading">
          <view class="learning-modal-title">学习情况</view>
          <view class="learning-modal-sub">{{learningStatusStudent.name || '-'}} · {{learningStatusStudent.statusText || '-'}}</view>
        </view>
        <view class="learning-modal-close" catchtap="closeLearningStatusModal">×</view>
      </view>

      <view wx:if="{{learningStatusLoading}}" class="learning-modal-state">学习情况加载中...</view>
      <view wx:elif="{{learningStatusError}}" class="learning-modal-state error">{{learningStatusError}}</view>
      <view wx:else class="learning-modal-body">
        <view class="learning-student-line">
          <text class="learning-student-name">{{learningStatus.student.name || learningStatusStudent.name || '-'}}</text>
          <text class="learning-state-badge state-{{learningStatus.summary.state}}">{{learningStatus.summary.stateText}}</text>
        </view>
        <view class="learning-bank-line">
          <text>{{learningStatus.bank ? learningStatus.bank.displayName : '未匹配到可用题库'}}</text>
        </view>

        <view class="learning-metric-grid">
          <view class="learning-metric">
            <text class="learning-metric-label">已掌握</text>
            <text class="learning-metric-value">{{learningStatus.summary.masteredCount}}/{{learningStatus.summary.questionCount}}</text>
          </view>
          <view class="learning-metric">
            <text class="learning-metric-label">错题</text>
            <text class="learning-metric-value">{{learningStatus.summary.wrongCount}}</text>
          </view>
          <view class="learning-metric">
            <text class="learning-metric-label">已浏览</text>
            <text class="learning-metric-value">{{learningStatus.summary.seenCount}}</text>
          </view>
          <view class="learning-metric">
            <text class="learning-metric-label">未做</text>
            <text class="learning-metric-value">{{learningStatus.summary.untouchedCount}}</text>
          </view>
        </view>

        <view class="learning-progress-box">
          <view class="learning-progress-head">
            <text>学习覆盖</text>
            <text>{{learningStatus.summary.studyProgressPercent}}%</text>
          </view>
          <view class="learning-progress-track">
            <view class="learning-progress-bar" style="width: {{learningStatus.summary.studyProgressPercent}}%;"></view>
          </view>
          <view class="learning-progress-note">
            已答 {{learningStatus.summary.answeredCount}} 题，正确率 {{learningStatus.summary.correctRate}}%，掌握率 {{learningStatus.summary.masteryPercent}}%
          </view>
          <view class="learning-progress-note" style="margin-top: 8rpx; color: #1e293b; font-weight: 500;">
            累计学时：{{learningStatus.summary.studyDurationText || '-'}} · 最近：{{learningStatus.summary.lastStudyTimeText || '-'}}
          </view>
        </view>

        <view class="learning-exam-box">
          <view class="learning-section-head">
            <text class="learning-section-title">模拟考试</text>
            <text class="learning-section-sub">通过 {{learningStatus.summary.passCount}} 次</text>
          </view>
          <view wx:if="{{learningStatus.examStats.latest}}" class="learning-exam-latest">
            <text class="learning-exam-score">{{learningStatus.examStats.latest.score}}分</text>
            <text class="learning-exam-result {{learningStatus.examStats.latest.passed ? 'passed' : 'failed'}}">{{learningStatus.examStats.latest.passed ? '通过' : '未通过'}}</text>
            <text class="learning-exam-time">{{learningStatus.examStats.latest.timeText || '-'}}</text>
          </view>
          <view wx:else class="learning-empty-line">暂无模拟考试记录</view>
        </view>

        <view class="learning-activity-box">
          <view class="learning-section-head">
            <text class="learning-section-title">考试动态</text>
            <text class="learning-section-sub">共 {{learningStatus.examStats.records.length}} 条</text>
          </view>
          <scroll-view class="learning-activity-scroll" scroll-y enhanced show-scrollbar="{{true}}">
            <view wx:if="{{!learningStatus.examStats.records.length}}" class="learning-empty-line">暂无考试记录</view>
            <view wx:else class="learning-activity-list">
              <view class="learning-activity-item" wx:for="{{learningStatus.examStats.records}}" wx:key="id">
                <view class="learning-activity-side">
                  <view class="learning-activity-type type-exam">模拟考试</view>
                  <view class="learning-activity-time">{{item.shortTimeText || '-'}}</view>
                </view>
                <view class="learning-activity-main">
                  <view class="learning-activity-primary">{{item.scoreText}} · {{item.resultText}}</view>
                  <view class="learning-activity-secondary">总题数 {{item.total || 0}}，答对 {{item.correctCount || 0}}，用时{{item.durationText || '-'}}</view>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="learning-modal-footer">
        <button class="learning-modal-btn ghost" catchtap="refreshLearningStatus" loading="{{learningStatusLoading}}" disabled="{{learningStatusLoading}}">刷新</button>
        <button class="learning-modal-btn primary" catchtap="closeLearningStatusModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 操作记录弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showOperationLogModal}}" catchtap="closeOperationLogModal">
    <view class="operation-modal" catchtap="preventD">
      <view class="operation-modal-header">
        <view class="operation-modal-heading">
          <view class="operation-modal-title">📋 操作记录</view>
          <view class="operation-modal-sub">{{operationLogStudent.name || '-'}} · {{operationLogStudent.statusText || '-'}}</view>
        </view>
        <view class="operation-modal-close" catchtap="closeOperationLogModal">×</view>
      </view>

      <view class="operation-modal-info">
        <view class="operation-info-item">
          <text class="operation-info-label">单位</text>
          <text class="operation-info-value">{{operationLogStudent.company || '-'}}</text>
        </view>
        <view class="operation-info-item">
          <text class="operation-info-label">手机</text>
          <text class="operation-info-value">{{operationLogStudent.phone || '-'}}</text>
        </view>
      </view>

      <scroll-view class="operation-modal-scroll" scroll-y enhanced show-scrollbar="{{true}}">
        <view class="operation-modal-state" wx:if="{{operationLogsLoading}}">操作记录加载中...</view>
        <view class="operation-modal-state error" wx:elif="{{operationLogsError}}">{{operationLogsError}}</view>
        <view class="operation-modal-state" wx:elif="{{!operationLogs.length}}">暂无操作记录</view>
        <view class="operation-timeline" wx:else>
          <view class="operation-log-item" wx:for="{{operationLogs}}" wx:key="id">
            <view class="operation-log-rail">
              <view class="operation-log-dot status-{{item.statusClass}}"></view>
            </view>
            <view class="operation-log-body">
              <view class="operation-log-main">
                <text class="operation-log-action">{{item.actionText}}</text>
                <text class="operation-log-status status-{{item.statusClass}}">{{item.statusText}}</text>
              </view>
              <view class="operation-log-meta">{{item.timeText}} · {{item.actorText}}</view>
              <view class="operation-log-message" wx:if="{{item.message}}">{{item.message}}</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="operation-modal-footer">
        <button class="operation-modal-btn ghost" catchtap="refreshOperationLogs" loading="{{operationLogsLoading}}" disabled="{{operationLogsLoading}}">刷新</button>
        <button class="operation-modal-btn primary" catchtap="closeOperationLogModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 报名表下载进度弹窗 -->
  <view class="log-overlay" wx:if="{{showRegFormLogModal}}" catchtap="">
    <view class="log-modal">
      <view class="log-modal-header">
        <text class="log-modal-title">{{regFormLogTitle || '📄 报名申请表'}}</text>
        <text class="log-modal-close" catchtap="closeRegFormLogModal" wx:if="{{!regFormLoading}}">✕</text>
      </view>
      <scroll-view class="log-modal-body" scroll-y scroll-into-view="{{regFormLogAnchor}}" enhanced show-scrollbar="{{false}}">
        <view class="log-line" wx:for="{{regFormLogs}}" wx:key="index">
          <text class="log-dot {{item.done ? 'done' : (item.error ? 'error' : 'running')}}">{{item.done ? '✅' : (item.error ? '❌' : '⏳')}}</text>
          <text class="log-text">{{item.text}}</text>
        </view>
        <view id="regFormLogBottom"></view>
      </scroll-view>
      <view class="log-modal-footer" wx:if="{{regFormError}}">
        <button class="log-retry-btn" catchtap="onRetryRegForm">重新尝试</button>
      </view>
    </view>
  </view>
  <!-- 更多操作弹窗 -->
  <view class="custom-modal-mask fade-enter" wx:if="{{showMoreActionsModal}}" catchtap="closeMoreActionsModal">
    <view class="more-actions-sheet" catchtap="preventD">
      <view class="more-actions-header">
        <view class="more-actions-title">更多操作</view>
        <view class="more-actions-sub">{{moreActionsStudent.name || '-'}} · {{moreActionsStudent.statusText || '-'}}</view>
      </view>
      <view class="more-actions-list">
        <view
          wx:if="{{moreActionsStudent.actions.canReject}}"
          class="more-action-item more-action-reject"
          hover-class="more-action-hover"
          catchtap="onMoreReject"
        >
          <view class="more-action-icon">↩️</view>
          <view class="more-action-text">
            <text class="more-action-label">驳回</text>
            <text class="more-action-desc">退回该学员，需填写原因</text>
          </view>
          <text class="more-action-arrow">›</text>
        </view>

        <view
          class="more-action-item more-action-log"
          hover-class="more-action-hover"
          catchtap="onMoreOperationLog"
        >
          <view class="more-action-icon">📋</view>
          <view class="more-action-text">
            <text class="more-action-label">操作记录</text>
            <text class="more-action-desc">查看该学员所有操作历史</text>
          </view>
          <text class="more-action-arrow">›</text>
        </view>
      </view>
      <view class="more-actions-footer">
        <button class="more-actions-cancel" catchtap="closeMoreActionsModal">取消</button>
      </view>
    </view>
  </view>

</view>
