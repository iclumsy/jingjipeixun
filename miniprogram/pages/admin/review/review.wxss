.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f8ff 0%, #f6f9ff 35%);
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(150rpx + constant(safe-area-inset-bottom));
}

.top-card {
  margin-bottom: 14rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.top-count {
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
}

.top-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7c93;
  line-height: 1.6;
}

.filter-card {
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-title {
  width: 76rpx;
  flex: 0 0 76rpx;
  line-height: 54rpx;
  font-size: 24rpx;
  color: #334155;
  font-weight: 600;
}

.chip-list {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-chip {
  border-radius: 999rpx;
  border: 2rpx solid #d0def0;
  background: #f7fbff;
  color: #6b7c93;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  line-height: 1;
}

.filter-chip.active {
  border-color: transparent;
  background: linear-gradient(135deg, #2f6af5 0%, #3a82ff 100%);
  color: #ffffff;
}

.company-picker {
  flex: 1;
  min-width: 0;
}

.picker-value {
  width: 100%;
  height: 54rpx;
  border-radius: 12rpx;
  border: 2rpx solid #d0def0;
  background: #f7fbff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  font-size: 23rpx;
  color: #334155;
}

.record-list {
  min-height: 420rpx;
}

.record-card {
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border: 1rpx solid #dce6f2;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 41, 67, 0.08);
  padding: 18rpx;
  margin-bottom: 14rpx;
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.name-wrap {
  min-width: 0;
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-text {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #9aa8bc;
}

.status-badge {
  border-radius: 999rpx;
  padding: 5rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge-unreviewed {
  background: #fff6df;
  color: #9a5600;
}

.badge-reviewed {
  background: #eaf9ef;
  color: #15803d;
}

.badge-rejected {
  background: #ffeceb;
  color: #b42318;
}

.meta-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-chip {
  max-width: 100%;
  border-radius: 10rpx;
  border: 1rpx solid #dfe9f6;
  background: #f2f7ff;
  color: #2f5fc8;
  font-size: 20rpx;
  line-height: 1;
  padding: 8rpx 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.detail-line {
  display: flex;
  align-items: center;
  font-size: 23rpx;
  line-height: 1.45;
}

.detail-label {
  width: 72rpx;
  flex: 0 0 72rpx;
  color: #6b7c93;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #334155;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 单位/证件/手机 信息区 + 右侧体检表按钮 */
.detail-with-form {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.detail-with-form .detail-list {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

/* 体检表侧边按钮（view 实现，flex 居中完全生效） */
.form-side-btn {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #f0ebff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.form-side-emoji {
  font-size: 42rpx;
  line-height: 1;
}

.form-side-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #6d28d9;
  line-height: 1;
}


.record-actions {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
}

.action-btn {
  flex: 1 1 0;
  margin: 0;
  border: none;
  border-radius: 12rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 0;
  min-width: 0;
}

.action-btn::after {
  border: none;
}

.btn-approve {
  background: #eaf9ef;
  color: #15803d;
}

.btn-reject {
  background: #ffeceb;
  color: #b42318;
}

.btn-delete {
  background: #fff2eb;
  color: #c2410c;
}

.btn-activate-card {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
}

/* 卡片头部「已通过」标签旁的开卡按钮 */
.card-head-activate-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 24rpx;
  height: 52rpx;
  border-radius: 29rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(14, 165, 233, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.disabled {
  opacity: 0.45;
}

/* ================================== */
/* 自定义开卡确认弹窗样式 */
/* ================================== */
.custom-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 99998;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-modal-box {
  width: min(600rpx, 92vw);
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
}

.activate-modal-header {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  padding: 30rpx 32rpx;
}

.activate-modal-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.activate-modal-sub {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.activate-modal-body {
  padding: 40rpx 32rpx;
}

.activate-info-grid {
  background: #f0f9ff;
  border: 2rpx solid #bae6fd;
  border-radius: 16rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 110rpx 1fr;
  gap: 16rpx 12rpx;
  margin-bottom: 30rpx;
}

.grid-label {
  color: #64748b;
  font-size: 26rpx;
  font-weight: 500;
}

.grid-value {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}

.grid-name { font-size: 30rpx; font-weight: 700; }
.grid-phone { color: #0369a1; letter-spacing: 1rpx; }
.grid-id { letter-spacing: 0.5rpx; }
.grid-project { color: #0369a1; }

.activate-warning {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  color: #d97706;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fffbeb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.warning-icon { margin-top: 2rpx; }
.warning-text { flex: 1; }

.activate-modal-footer {
  display: flex;
  padding: 0 32rpx 40rpx;
  gap: 20rpx;
}

.activate-btn-cancel,
.activate-btn-confirm {
  flex: 1;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
}

.activate-btn-cancel {
  background: #f1f5f9;
  color: #475569;
  border: none;
}

.activate-btn-confirm {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(14, 165, 233, 0.35);
}

.activate-btn-confirm[disabled] {
  opacity: 0.6;
}

.activate-btn-cancel::after,
.activate-btn-confirm::after {
  border: none;
}

.loading,
.no-more {
  text-align: center;
  padding: 20rpx 0;
  color: #9aa8bc;
  font-size: 22rpx;
}
