.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f8ff 0%, #f6f9ff 35%);
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(150rpx + constant(safe-area-inset-bottom));
}

.top-card {
  margin-bottom: 14rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.top-count {
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
}

.top-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7c93;
  line-height: 1.6;
}

.filter-card {
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-title {
  width: 76rpx;
  flex: 0 0 76rpx;
  line-height: 54rpx;
  font-size: 24rpx;
  color: #334155;
  font-weight: 600;
}

.chip-list {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-chip {
  border-radius: 999rpx;
  border: 2rpx solid #d0def0;
  background: #f7fbff;
  color: #6b7c93;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  line-height: 1;
}

.filter-chip.active {
  border-color: transparent;
  background: linear-gradient(135deg, #2f6af5 0%, #3a82ff 100%);
  color: #ffffff;
}

.company-picker {
  flex: 1;
  min-width: 0;
}

.picker-value {
  width: 100%;
  height: 54rpx;
  border-radius: 12rpx;
  border: 2rpx solid #d0def0;
  background: #f7fbff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  font-size: 23rpx;
  color: #334155;
}

.record-list {
  min-height: 420rpx;
}

.record-card {
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border: 1rpx solid #dce6f2;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 41, 67, 0.08);
  padding: 18rpx;
  margin-bottom: 14rpx;
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.name-wrap {
  min-width: 0;
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-text {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #9aa8bc;
}

.status-badge {
  border-radius: 999rpx;
  padding: 5rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge-unreviewed {
  background: #fff6df;
  color: #9a5600;
}

.badge-reviewed {
  background: #eaf9ef;
  color: #15803d;
}

.badge-rejected {
  background: #ffeceb;
  color: #b42318;
}

.badge-registered {
  background: #e0e7ff;
  color: #3730a3;
}

.meta-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-chip {
  max-width: 100%;
  border-radius: 10rpx;
  border: 1rpx solid #dfe9f6;
  background: #f2f7ff;
  color: #2f5fc8;
  font-size: 20rpx;
  line-height: 1;
  padding: 8rpx 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.detail-line {
  display: flex;
  align-items: center;
  font-size: 23rpx;
  line-height: 1.45;
}

.detail-label {
  width: 72rpx;
  flex: 0 0 72rpx;
  color: #6b7c93;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #334155;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 单位/证件/手机 信息区 + 右侧体检表按钮 */
.detail-with-form {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.detail-with-form .detail-list {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

/* 体检表侧边按钮（view 实现，flex 居中完全生效） */
.form-side-btn {
  flex-shrink: 0;
  width: 90rpx;
  height: 90rpx;
  border-radius: 14rpx;
  background: #f0ebff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.form-side-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.form-side-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.btn-form-health {
  background: #f0ebff;
  color: #6d28d9;
}

.btn-form-reg {
  background: #e0f2fe;
  color: #0369a1;
}


.record-actions {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
}

.action-btn {
  flex: 1 1 0;
  margin: 0;
  border-radius: 14rpx;
  height: 60rpx;
  line-height: 58rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0;
  min-width: 0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.btn-approve {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  color: #15803d;
  border: 1rpx solid #bbf7d0;
}

.btn-reject {
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  color: #b45309;
  border: 1rpx solid #fde68a;
}

.btn-delete {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
  color: #b91c1c;
  border: 1rpx solid #fecaca;
}

.card-query-chip {
  margin-left: auto;
  background: #dcfce7;
  color: #15803d;
  border-color: #bbf7d0;
  font-weight: 600;
  padding: 6rpx 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.card-activate-chip {
  margin-left: auto;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  border: none;
  font-weight: 600;
  padding: 6rpx 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-activate-card {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
}

/* 卡片头部「已通过」标签旁的开卡按钮 */
.card-head-activate-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 24rpx;
  height: 52rpx;
  border-radius: 29rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(14, 165, 233, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-head-activate-btn.activated {
  background: #e2e8f0;
  color: #64748b;
  box-shadow: none;
  font-weight: 600;
}

.action-btn.disabled {
  opacity: 0.45;
}

/* ================================== */
/* 自定义开卡确认弹窗样式 */
/* ================================== */
.custom-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 99998;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-modal-box {
  width: min(600rpx, 92vw);
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
}

.activate-modal-header {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  padding: 30rpx 32rpx;
}

.activate-modal-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.activate-modal-sub {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.activate-modal-body {
  padding: 40rpx 32rpx;
}

.activate-info-grid {
  background: #f0f9ff;
  border: 2rpx solid #bae6fd;
  border-radius: 16rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 110rpx 1fr;
  gap: 16rpx 12rpx;
  margin-bottom: 30rpx;
}

.grid-label {
  color: #64748b;
  font-size: 26rpx;
  font-weight: 500;
}

.grid-value {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}

.grid-name { font-size: 30rpx; font-weight: 700; }
.grid-phone { color: #0369a1; letter-spacing: 1rpx; }
.grid-id { letter-spacing: 0.5rpx; }
.grid-project { color: #0369a1; }

.activate-warning {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  color: #d97706;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fffbeb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.warning-icon { margin-top: 2rpx; }
.warning-text { flex: 1; }

.activate-modal-footer {
  display: flex;
  padding: 0 32rpx 40rpx;
  gap: 20rpx;
}

.activate-btn-cancel,
.activate-btn-confirm {
  flex: 1;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
}

.activate-btn-cancel {
  background: #f1f5f9;
  color: #475569;
  border: none;
}

.activate-btn-confirm {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(14, 165, 233, 0.35);
}

.activate-btn-confirm[disabled] {
  opacity: 0.6;
}

.activate-btn-cancel::after,
.activate-btn-confirm::after {
  border: none;
}

.loading,
.no-more {
  text-align: center;
  padding: 20rpx 0;
  color: #9aa8bc;
  font-size: 22rpx;
}

.reject-reason-row {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  background: #fff5f5;
  border: 1rpx solid #fed7d7;
  border-radius: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.reject-label {
  flex: 0 0 auto;
  font-size: 22rpx;
  color: #c53030;
  font-weight: 600;
  line-height: 1.5;
}

.reject-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #9b2c2c;
  line-height: 1.5;
  word-break: break-all;
}


/* --- 学习卡信息展示弹窗 --- */
.card-info-modal {
  position: relative;
  width: 90%;
  max-width: 680rpx;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
}

.card-info-header {
  background: linear-gradient(135deg, #0ea5e9, #6366f1);
  padding: 36rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.card-info-icon {
  font-size: 56rpx;
  line-height: 1;
}

.card-info-header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-info-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.card-info-sub {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.card-info-state {
  padding: 6rpx 18rpx;
  border-radius: 99rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.state-valid {
  background: #dcfce7;
  color: #15803d;
}

.state-other {
  background: #fef3c7;
  color: #92400e;
}

.card-info-body {
  padding: 32rpx 40rpx;
  background: #ffffff;
  overflow-y: auto;
  flex: 1;
}

.card-info-section-title {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.card-info-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-info-item {
  width: 48%;
  display: flex;
  flex-direction: column;
}

.card-info-full {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.card-info-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 2rpx;
}

.card-info-value {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
}

.card-info-value.bold {
  font-weight: 600;
}

.card-info-value.mono {
  font-variant-numeric: tabular-nums;
}

.card-info-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
  margin: 28rpx 0;
}

.card-info-card-box {
  background: linear-gradient(135deg, #f0f9ff, #eef2ff);
  border: 2rpx solid #bae6fd;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-info-card-item {
  display: flex;
  flex-direction: column;
}

.card-info-card-item.right {
  text-align: right;
}

.card-info-card-label {
  font-size: 22rpx;
  color: #0369a1;
}

.card-info-card-value {
  font-size: 32rpx;
  color: #0c4a6e;
  font-weight: 700;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

.card-info-card-sep {
  width: 2rpx;
  height: 64rpx;
  background: #bae6fd;
}

.card-info-footer {
  padding: 0 40rpx 40rpx;
}

.card-info-close-btn {
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(139, 92, 246, 0.25);
  border: none;
}

.card-info-close-btn::after {
  border: none;
}

/* ========== 通用实时日志弹窗（明亮风格） ========== */
.log-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35); z-index: 9999;
  display: flex; align-items: center; justify-content: center;
}
.log-modal {
  width: 85%; max-height: 70vh;
  background: #ffffff; border-radius: 24rpx;
  overflow: hidden; display: flex; flex-direction: column;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.log-modal-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 32rpx; border-bottom: 1rpx solid #e5e7eb;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
}
.log-modal-title {
  font-size: 30rpx; font-weight: 600; color: #1e293b;
}
.log-modal-close {
  font-size: 36rpx; color: #94a3b8; padding: 0 10rpx;
}
.log-modal-body {
  padding: 20rpx 32rpx; flex: 1; max-height: 50vh;
  background: #fafbfc;
}
.log-line {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 12rpx 0; animation: logFadeIn 0.3s ease;
  border-bottom: 1rpx solid #f1f5f9;
}
.log-line:last-child { border-bottom: none; }
@keyframes logFadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.log-dot {
  font-size: 28rpx; flex-shrink: 0; width: 40rpx; text-align: center;
}
.log-text {
  font-size: 26rpx; color: #475569; line-height: 1.5;
}
.log-dot.done + .log-text { color: #16a34a; }
.log-dot.error + .log-text { color: #dc2626; }
.log-dot.running + .log-text { color: #2563eb; }
.log-modal-footer {
  padding: 20rpx 32rpx; border-top: 1rpx solid #e5e7eb;
  background: #f8fafc;
}
.log-retry-btn {
  width: 100%; padding: 18rpx 0;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: #fff; border-radius: 16rpx; font-size: 28rpx;
  font-weight: 600; border: none;
}
.log-retry-btn::after { border: none; }

