.history-list-page {
  min-height: 100vh;
  background-color: #f3f6fb;
  padding: 30rpx;
  box-sizing: border-box;
}

.header-card {
  background: linear-gradient(135deg, #2f6af5, #5f92ff);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(47, 106, 245, 0.15);
}

.bank-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.85;
}

.list-container {
  padding-bottom: 40rpx;
}

.state-hint {
  text-align: center;
  padding: 80rpx 0;
  color: #64748b;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #334155;
  margin-top: 30rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 10rpx;
  text-align: center;
}

.record-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.record-card:active {
  transform: translateY(2rpx);
  background-color: #f8fafc;
}

.card-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.score-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.score-num {
  font-size: 54rpx;
  font-weight: 800;
  font-family: 'Outfit', 'Inter', sans-serif;
  line-height: 1;
}

.score-unit {
  font-size: 26rpx;
  color: #64748b;
  margin-left: 6rpx;
  margin-right: 20rpx;
  font-weight: 600;
}

.pass-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  vertical-align: middle;
}

.pass-color {
  color: #10b981;
}

.fail-color {
  color: #ef4444;
}

.pass-bg {
  background-color: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.fail-bg {
  background-color: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #475569;
}

.meta-divider {
  color: #cbd5e1;
  margin: 0 16rpx;
  font-size: 22rpx;
}

.time-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.card-right {
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}

.action-link {
  font-size: 26rpx;
  color: #2f6af5;
  font-weight: 600;
}

.arrow {
  font-size: 26rpx;
  color: #2f6af5;
  margin-left: 8rpx;
  transition: transform 0.2s ease;
}

.record-card:active .arrow {
  transform: translateX(4rpx);
}

.record-card-hover {
  transform: translateY(2rpx);
  background-color: #f1f5f9;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.record-card-hover .arrow {
  transform: translateX(4rpx);
}
