<view class="history-list-page">
  <view class="header-card">
    <view class="bank-title">{{bankTitle}}</view>
    <view class="header-desc">历次模拟考试记录归档</view>
  </view>

  <view class="list-container">
    <view wx:if="{{loading && list.length === 0}}" class="state-hint">正在加载历史记录...</view>
    
    <view wx:elif="{{list.length === 0}}" class="empty-state">
      <icon type="info" size="64" color="#cbd5e1" />
      <view class="empty-title">暂无模拟考试记录</view>
      <view class="empty-desc">您尚未在此题库中进行过模拟考试</view>
    </view>

    <view wx:else>
      <view 
        wx:for="{{list}}" 
        wx:key="id" 
        class="record-card" 
        hover-class="record-card-hover"
        data-id="{{item.id}}" 
        bindtap="viewDetail"
      >
        <view class="card-left">
          <view class="score-row">
            <text class="score-num {{item.passed ? 'pass-color' : 'fail-color'}}">{{item.score}}</text>
            <text class="score-unit">分</text>
            <text class="pass-badge {{item.passed ? 'pass-bg' : 'fail-bg'}}">{{item.passed ? '及格' : '不及格'}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-item">用时：{{item.durationText}}</text>
            <text class="meta-divider">|</text>
            <text class="meta-item">答对：{{item.correct_count}}/{{item.total}}题</text>
          </view>
          <view class="time-text">{{item.dateText}}</view>
        </view>
        <view class="card-right">
          <text class="action-link">查看答卷</text>
          <text class="arrow">➔</text>
        </view>
      </view>
    </view>
  </view>
</view>
