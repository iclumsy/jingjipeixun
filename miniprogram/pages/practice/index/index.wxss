.practice-page {
  min-height: 100vh;
  background: #f3f6fb;
  padding: 28rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header {
  padding: 22rpx 4rpx 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #15233d;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #697994;
}

.state {
  margin-top: 80rpx;
  text-align: center;
  color: #697994;
  font-size: 28rpx;
}

.primary-btn {
  margin-top: 24rpx;
  background: #2f6af5;
  color: #fff;
}

.bank-tabs {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.bank-tab {
  display: inline-flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #697994;
  border: 1rpx solid #dce6f2;
  font-size: 24rpx;
}

.bank-tab.active {
  background: #2f6af5;
  color: #fff;
  border-color: #2f6af5;
}

.hero-card,
.filter-section {
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(19, 37, 69, 0.06);
}

.bank-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #15233d;
}

.bank-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #697994;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.stats view {
  background: #f5f8ff;
  border-radius: 12rpx;
  padding: 14rpx 8rpx;
  text-align: center;
}

.stats text:first-child {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.stats text:last-child {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #697994;
}

.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.mode-card {
  min-height: 188rpx;
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.mode-card:active {
  background: #f5f9ff;
}

.mode-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #15233d;
}

.mode-desc {
  margin-top: 10rpx;
  min-height: 68rpx;
  line-height: 1.45;
  color: #697994;
  font-size: 24rpx;
}

.mode-detail {
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-section {
  margin-top: 22rpx;
}

.section-title {
  color: #15233d;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chips button {
  min-height: 68rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1d4ed8;
  font-size: 24rpx;
}
