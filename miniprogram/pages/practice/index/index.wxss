.practice-page {
  min-height: 100vh;
  background: #f3f6fb;
  padding: 24rpx 24rpx calc(240rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header {
  padding: 22rpx 4rpx 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #15233d;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #697994;
}

.state {
  margin-top: 80rpx;
  text-align: center;
  color: #697994;
  font-size: 28rpx;
}

.state-card {
  margin-top: 60rpx;
  padding: 44rpx 30rpx;
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(19, 37, 69, 0.06);
}

.state-title {
  color: #15233d;
  font-size: 32rpx;
  font-weight: 700;
}

.state-desc {
  margin-top: 12rpx;
  color: #697994;
  font-size: 26rpx;
  line-height: 1.5;
}

.primary-btn {
  margin-top: 24rpx;
  background: #2f6af5;
  color: #fff;
}

.bank-tabs {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.bank-tab {
  display: inline-flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #697994;
  border: 1rpx solid #dce6f2;
  font-size: 24rpx;
}

.bank-tab.active {
  background: #2f6af5;
  color: #fff;
  border-color: #2f6af5;
}

.hero-card,
.action-card,
.filter-section {
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(19, 37, 69, 0.06);
}

.bank-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.bank-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #15233d;
  line-height: 1.3;
}

.bank-pill {
  flex: 0 0 auto;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f0fdf4;
  color: #15803d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.stats.secondary {
  margin-top: 12rpx;
}

.stats view {
  background: #f5f8ff;
  border-radius: 12rpx;
  padding: 14rpx 8rpx;
  text-align: center;
}

.stats text:first-child {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.stats text:last-child {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #697994;
}

.progress-block {
  margin-top: 22rpx;
}

.progress-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #697994;
  font-size: 24rpx;
}

.progress-copy text:last-child {
  color: #15233d;
  font-weight: 700;
}

.progress-track {
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e8eef7;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #16a34a;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  border-color: #bfd2ff;
  background: #f8fbff;
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-eyebrow {
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.action-title {
  margin-top: 6rpx;
  color: #15233d;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.action-detail {
  margin-top: 8rpx;
  color: #697994;
  font-size: 24rpx;
  line-height: 1.4;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  min-height: 72rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 14rpx;
  border: 0;
  background: #2f6af5;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  box-sizing: border-box;
}

.action-btn::after {
  border: 0;
}

.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.mode-card {
  min-height: 188rpx;
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.mode-card:active {
  background: #f5f9ff;
}

.mode-card.muted {
  opacity: 0.62;
}

.mode-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #15233d;
}

.mode-desc {
  margin-top: 10rpx;
  min-height: 68rpx;
  line-height: 1.45;
  color: #697994;
  font-size: 24rpx;
}

.mode-detail {
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
}

.section-title {
  color: #15233d;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.history-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #dce6f2;
}

.history-entry:active {
  opacity: 0.8;
}

.history-left {
  display: flex;
  align-items: center;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.history-title {
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 700;
}

.history-right {
  display: flex;
  align-items: center;
}

.history-desc {
  color: #697994;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.history-arrow {
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 700;
}
