.session-page {
  min-height: 100vh;
  background: #f3f6fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #15233d;
}

.meta {
  margin-top: 6rpx;
  color: #697994;
  font-size: 24rpx;
}

.timer {
  min-width: 120rpx;
  text-align: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #15233d;
  color: #fff;
  font-weight: 700;
}

.state {
  text-align: center;
  margin-top: 100rpx;
  color: #697994;
}

.question-card {
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 24rpx;
}

.q-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #15233d;
  font-weight: 600;
}

.options {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 22rpx;
  border: 1rpx solid #dce6f2;
  border-radius: 14rpx;
  background: #f8fbff;
}

.option.selected {
  border-color: #2f6af5;
  background: #eef4ff;
}

.option-key {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #dce8ff;
  color: #1d4ed8;
  text-align: center;
  line-height: 44rpx;
  font-weight: 700;
}

.option-text {
  flex: 1;
  line-height: 1.5;
  color: #25324a;
}

.result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.result.ok {
  background: #ecfdf3;
  color: #047857;
}

.result.bad {
  background: #fff1f2;
  color: #be123c;
}

.analysis {
  margin-top: 10rpx;
  color: #475569;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.actions button {
  min-height: 84rpx;
}

.actions .primary {
  background: #2f6af5;
  color: #fff;
}
