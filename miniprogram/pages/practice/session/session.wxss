.session-page {
  min-height: 100vh;
  background: #f3f6fb;
  padding: 24rpx 24rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.top-copy {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #15233d;
  line-height: 1.35;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 6rpx;
  color: #697994;
  font-size: 24rpx;
}

.timer {
  min-width: 120rpx;
  text-align: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #15233d;
  color: #fff;
  font-weight: 700;
}

.session-progress {
  height: 12rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e8eef7;
}

.session-progress-fill {
  height: 100%;
  min-width: 10rpx;
  border-radius: 999rpx;
  background: #2f6af5;
}

.type-filter {
  display: flex;
  width: 100%;
  padding: 6rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #cfe0f5;
  border-radius: 14rpx;
  background: #eef4fb;
  box-sizing: border-box;
  overflow: hidden;
}

.type-filter-btn {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 8rpx;
  border-radius: 10rpx;
  color: #697994;
  font-size: 24rpx;
  line-height: 58rpx;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.type-filter-btn.active {
  background: #fff;
  color: #1d4ed8;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(47, 106, 245, 0.16);
}

.mode-hint {
  margin-bottom: 20rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #dce6f2;
  color: #697994;
  font-size: 24rpx;
  line-height: 1.45;
}

.state {
  text-align: center;
  margin-top: 100rpx;
  color: #697994;
}

.question-card {
  background: #fff;
  border: 1rpx solid #dce6f2;
  border-radius: 16rpx;
  padding: 24rpx;
}

.q-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #697994;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.q-badge {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1d4ed8;
  font-weight: 700;
}

.q-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #15233d;
  font-weight: 600;
}

.question-images {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.question-image {
  width: 100%;
  border-radius: 12rpx;
  border: 1rpx solid #dce6f2;
  background: #f8fbff;
}

.options {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 22rpx;
  border: 1rpx solid #dce6f2;
  border-radius: 14rpx;
  background: #f8fbff;
}

.option.selected {
  border-color: #2f6af5;
  background: #eef4ff;
}

.option-key {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #dce8ff;
  color: #1d4ed8;
  text-align: center;
  line-height: 44rpx;
  font-weight: 700;
}

.option-text {
  display: block;
  width: 100%;
  line-height: 1.5;
  color: #25324a;
}

.option-body {
  flex: 1;
  min-width: 0;
}

.option-image {
  display: block;
  width: 100%;
  max-width: 460rpx;
  margin-top: 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid #dce6f2;
  background: #fff;
}

.result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.result.ok {
  background: #ecfdf3;
  color: #047857;
}

.result.bad {
  background: #fff1f2;
  color: #be123c;
}

.result.neutral {
  background: #f5f8ff;
  color: #1d4ed8;
}

.analysis {
  margin-top: 10rpx;
  color: #475569;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 84rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 0;
  border-radius: 12rpx;
  color: #25324a;
  font-size: 28rpx;
  line-height: 1.2;
  box-sizing: border-box;
  background: #eef2f7;
}

.actions button::after {
  border: 0;
}

.actions .primary {
  background: #2f6af5;
  color: #fff;
}

.card-toggle {
  position: fixed;
  right: 26rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 76rpx;
  min-height: 76rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 0;
  border-radius: 38rpx;
  background: #15233d;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 12rpx 28rpx rgba(21, 35, 61, 0.22);
  z-index: 70;
  box-sizing: border-box;
}

.card-toggle::after {
  border: 0;
}

.card-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 62vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 24rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -14rpx 34rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
  z-index: 80;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 700;
  color: #15233d;
  margin-bottom: 18rpx;
}

.card-head button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 22rpx;
  min-height: 56rpx;
  border: 0;
  border-radius: 999rpx;
  background: #eef2f7;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.2;
}

.card-head button::after {
  border: 0;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 10rpx;
  max-height: 40vh;
  overflow-y: auto;
}

.card-cell {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 10rpx;
  background: #f1f5f9;
  color: #475569;
  text-align: center;
  font-size: 24rpx;
}

.card-cell.answered {
  background: #dbeafe;
  color: #1d4ed8;
}

.card-cell.current {
  background: #15233d;
  color: #fff;
}

.finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin-top: 18rpx;
  border: 0;
  border-radius: 12rpx;
  background: #2f6af5;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.2;
}

.finish-btn::after {
  border: 0;
}
