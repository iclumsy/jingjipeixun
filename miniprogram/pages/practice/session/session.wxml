<view class="session-page">
  <view class="top">
    <view class="top-copy">
      <view class="title">{{title}}</view>
      <view class="meta-row">
        <text>{{currentPosition + 1}} / {{questionTotal || questions.length}}</text>
        <text wx:if="{{questions.length > 0}}">{{answeredLabel}} {{answeredCount}}</text>
      </view>
    </view>
    <view wx:if="{{mode === 'exam'}}" class="timer">{{timerText}}</view>
  </view>
  <view wx:if="{{questions.length > 0}}" class="session-progress">
    <view class="session-progress-fill" style="width: {{progressPercent}}%;"></view>
  </view>
  <view wx:if="{{showQuestionTypeFilter}}" class="type-filter">
    <view
      wx:for="{{questionTypeOptions}}"
      wx:key="value"
      class="type-filter-btn {{activeQuestionType === item.value ? 'active' : ''}}"
      data-type="{{item.value}}"
      bindtap="switchQuestionType"
    >{{item.label}}</view>
  </view>
  <view wx:if="{{modeHint}}" class="mode-hint">{{modeHint}}</view>

  <view wx:if="{{loading}}" class="state">正在加载题目...</view>
  <view wx:elif="{{questions.length === 0}}" class="state">暂无题目</view>

  <view wx:else class="question-card">
    <view class="q-head">
      <text class="q-badge">{{questions[currentIndex].question_type === 'multi' ? '多选题' : (questions[currentIndex].question_type === 'judge' ? '判断题' : (questions[currentIndex].question_type === 'case' ? '案例题' : '单选题'))}}</text>
      <text>第 {{currentIndex + 1}} 题</text>
    </view>
    <view class="q-text">{{questions[currentIndex].question}}</view>
    <view wx:if="{{questionImages.length > 0}}" class="question-images">
      <image
        wx:for="{{questionImages}}"
        wx:key="*this"
        class="question-image"
        mode="widthFix"
        src="{{item}}"
        show-menu-by-longpress
      />
    </view>
    <view class="options">
      <view
        wx:for="{{optionList}}"
        wx:for-item="option"
        wx:key="key"
        class="option {{option.selected ? 'selected' : ''}}"
        data-key="{{option.key}}"
        bindtap="selectOption"
      >
        <text class="option-key">{{option.key}}</text>
        <view class="option-body">
          <text class="option-text">{{option.text}}</text>
          <image wx:if="{{option.image}}" class="option-image" mode="widthFix" src="{{option.image}}" show-menu-by-longpress />
        </view>
      </view>
    </view>

    <view wx:if="{{mode === 'memorize'}}" class="result neutral">
      <view>正确答案：{{correctAnswerText}}</view>
      <view wx:if="{{questions[currentIndex].analysis}}" class="analysis">{{questions[currentIndex].analysis}}</view>
    </view>

    <view wx:elif="{{submitted && mode !== 'exam'}}" class="result {{isCorrect ? 'ok' : 'bad'}}">
      <view>{{isCorrect ? '回答正确' : '回答错误'}}</view>
      <view>正确答案：{{correctAnswerText}}</view>
      <view wx:if="{{questions[currentIndex].analysis}}" class="analysis">{{questions[currentIndex].analysis}}</view>
    </view>

    <view class="actions">
      <button bindtap="prevQuestion">上一题</button>
      <button wx:if="{{mode === 'memorize'}}" class="primary" bindtap="nextQuestion">{{currentPosition >= questionTotal - 1 ? '完成' : '下一题'}}</button>
      <button wx:elif="{{mode === 'exam'}}" class="primary" bindtap="submitAnswer">{{currentIndex >= questions.length - 1 ? '交卷' : '下一题'}}</button>
      <button wx:elif="{{!submitted}}" class="primary" bindtap="submitAnswer">确认答案</button>
      <button wx:else class="primary" bindtap="nextQuestion">{{currentPosition >= questionTotal - 1 ? '完成' : '下一题'}}</button>
    </view>
  </view>

  <button wx:if="{{mode === 'exam' && questions.length > 0}}" class="card-toggle" bindtap="toggleCard">答题卡</button>
  <view wx:if="{{showCard}}" class="card-panel">
    <view class="card-head">
      <text>答题卡</text>
      <button bindtap="toggleCard">关闭</button>
    </view>
    <view class="card-grid">
      <view
        wx:for="{{questions}}"
        wx:key="id"
        data-index="{{index}}"
        class="card-cell {{currentIndex === index ? 'current' : ''}} {{answerMap[item.id] ? 'answered' : ''}}"
        bindtap="jumpQuestion"
      >{{index + 1}}</view>
    </view>
    <button wx:if="{{mode === 'exam'}}" class="finish-btn" bindtap="finishSession">交卷</button>
  </view>
</view>
