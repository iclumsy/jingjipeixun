<view class="student-card card-{{statusClass}} tap-feedback fade-enter" bindtap="onTap">
  <view class="card-head">
    <view class="student-name">{{student.name || '未填写姓名'}}</view>
    <view class="status-badge badge-{{statusClass}}">{{statusText || '-'}}</view>
  </view>

  <view class="meta-row">
    <text class="meta-chip">{{trainingTypeText || '-'}}</text>
    <text class="meta-chip">{{student.job_category || '-'}}</text>
    <text wx:if="{{student.exam_project}}" class="meta-chip">{{student.exam_project}}</text>
  </view>

  <view class="detail-list">
    <view class="detail-line">
      <text class="detail-label">单位</text>
      <text class="detail-value">{{student.company || '-'}}</text>
    </view>
    <view class="detail-line">
      <text class="detail-label">证件</text>
      <text class="detail-value">{{student.id_card || '-'}}</text>
    </view>
    <view class="detail-line">
      <text class="detail-label">手机</text>
      <text class="detail-value">{{student.phone || '-'}}</text>
    </view>
  </view>

  <view wx:if="{{student.status === 'rejected' && student.reject_reason}}" class="reject-reason-row">
    <text class="reject-label">驳回原因</text>
    <text class="reject-text">{{student.reject_reason}}</text>
  </view>

  <view class="card-foot">
    <text class="time-text">{{createTime || '-'}}</text>
    <text class="entry-text">查看详情</text>
  </view>
</view>
