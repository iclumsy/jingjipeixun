/* 管理端卡片扩展（使用全局的 section-card 风格，但间距更紧凑） */
.admin-section-card {
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 1px solid #f0f0f0;
}

.admin-readonly-group {
  padding: 10rpx 24rpx 24rpx;
}

/* 一行排列多个子项，或者上下排列 */
.admin-fields-grid {
  display: flex;
  flex-wrap: wrap;
  column-gap: 20rpx;
  padding: 10rpx 24rpx 10rpx;
}

.admin-compact-input {
  box-sizing: border-box;
  margin-bottom: 16rpx;
  background: #fdfdfd;
  border: 1rpx solid #f5f5f5;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.admin-compact-input .label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.admin-compact-input .input,
.admin-compact-input .picker-input {
  font-size: 28rpx;
  color: #333;
  width: 100%;
}

.admin-inline-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx dashed #f0f0f0;
}
.admin-inline-item:last-child {
  border-bottom: none;
}
.admin-inline-item .label {
  margin-bottom: 0;
  width: 160rpx;
}
.admin-inline-item .type-options {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}
.admin-inline-item picker {
  flex: 1;
}

/* 附件区域：直接粘附在表单字段下方 */
.admin-attachments-zone {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx dashed #eee;
  margin-top: 8rpx;
}

.admin-attachment-pair {
  margin-top: 20rpx;
  background: #fafafc;
  border-radius: 12rpx;
  padding: 16rpx;
}

.admin-pair-title {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.admin-pair-title::before {
  content: "";
  display: inline-block;
  width: 6rpx;
  height: 20rpx;
  background: #c7d2fe;
  margin-right: 12rpx;
  border-radius: 4rpx;
}

/* 互换按钮栏靠下中对齐 */
.admin-swap-bar {
  display: flex;
  justify-content: center;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #eef2ff;
}

.swap-inline-btn {
  height: 52rpx;
  margin: 0;
  padding: 0 32rpx;
  border-radius: 26rpx;
  border: 1rpx solid #c7d2fe;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
  line-height: 50rpx;
  box-shadow: 0 2rpx 6rpx rgba(79, 70, 229, 0.1);
}
