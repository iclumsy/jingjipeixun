/* 整体面板：抛弃笨重感，使用极简白色区块 */
.admin-panel {
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 4rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 单元格布局：绝对精简的单行排布 */
.admin-cell {
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 8rpx 8rpx;
  border-bottom: 1rpx solid #fafafa;
}
.admin-cell:last-child {
  border-bottom: none;
}

.cell-label {
  width: 130rpx;
  font-size: 26rpx;
  color: #777;
  flex-shrink: 0;
}
.cell-label.required::before {
  content: "*";
  color: #ff4d4f;
  margin-right: 4rpx;
}

.cell-body {
  flex: 1;
  display: flex;
  align-items: center;
}
.cell-body.right {
  justify-content: flex-end;
}

/* 让 input 拥有信息采集页同款结构边框 */
.cell-input {
  width: 100%;
  height: 64rpx;
  font-size: 28rpx;
  color: #0f172a;
  background: #f8fbff;
  border: 2rpx solid #dce6f2;
  padding: 0 20rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 选择器文本样式 */
picker {
  width: 100%;
}
.picker-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  height: 64rpx;
  background: #f8fbff;
  border: 2rpx solid #dce6f2;
  padding: 0 20rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.picker-inner .val {
  color: #0f172a;
}
.picker-inner .plc {
  color: #9aa8bc;
}
.picker-inner .arrow {
  color: #9aa8bc;
  margin-left: auto;
}

/* 选项按钮池，高度压至最低，色彩现代化 */
.btn-group {
  display: flex;
  gap: 12rpx;
}

.btn-item {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  color: #555;
  background: #f4f5f7;
  transition: all 0.2s;
  border: 1rpx solid transparent;
}

.btn-item.active {
  background: #eef2ff;
  border-color: #d6e4ff;
  color: #2f6af5;
  font-weight: 600;
}

/* 照片区域，与最后一个单元格无缝衔接 */
.admin-photo-zone {
  padding: 16rpx 8rpx;
  border-top: 1rpx dashed #f0f0f0;
}

.photo-pair {
  margin-bottom: 24rpx;
}
.photo-pair:last-child {
  margin-bottom: 0;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.photo-item {
  flex: 1;
  min-width: 45%;
}

/* 小巧的互换药丸按钮 */
.swap-bar {
  display: flex;
  justify-content: center;
  margin-top: 12rpx;
}
.swap-btn-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 40rpx;
  border-radius: 28rpx;
  background: #eaf1ff;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid #c7d2fe;
  box-shadow: 0 2rpx 6rpx rgba(29, 78, 216, 0.08);
}
.swap-btn-pill:active {
  opacity: 0.8;
}
