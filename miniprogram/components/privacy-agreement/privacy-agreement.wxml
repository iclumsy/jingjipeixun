<!-- components/privacy-agreement/privacy-agreement.wxml -->
<view class="privacy-mask" wx:if="{{show}}">
  <view class="privacy-backdrop" catchtouchmove="preventTouchMove"></view>
  <view class="privacy-dialog">
    <view class="dialog-header">
      <text class="dialog-title">用户隐私保护提示</text>
    </view>

    <view class="dialog-content">
      <view class="content-text">
        <text>欢迎使用阳泉精技培训管理小程序。继续使用前，请先阅读并同意相关协议。</text>
      </view>

      <view class="summary-card">
        <view class="section-title">我们会收集什么</view>
        <view class="info-list">
          <text class="info-item">• 学员基本信息、联系方式、报名项目</text>
          <text class="info-item">• 身份证、学历证书、户口本等报名附件</text>
          <text class="info-item">• 微信 OpenID，用于识别提交人</text>
        </view>
      </view>

      <view class="summary-card">
        <view class="section-title">我们如何使用</view>
        <view class="info-list">
          <text class="info-item">• 用于培训报名资料提交、审核与办理</text>
          <text class="info-item">• 用于查看审核状态、驳回修改与通知提醒</text>
          <text class="info-item">• 不用于与培训报名无关的用途</text>
        </view>
      </view>

      <view class="agreement-link-row">
        <text class="content-text inline-text">查看完整内容：</text>
        <text class="link" bindtap="openUserAgreement">《用户服务协议》</text>
        <text class="link-sep">和</text>
        <text class="link" bindtap="openPrivacyPolicy">《隐私政策》</text>
      </view>

      <view class="content-text highlight">
        <text>点击“同意”即表示您已阅读并接受以上协议。</text>
      </view>
    </view>

    <view class="dialog-footer">
      <button class="btn btn-secondary" bindtap="onDisagree">不同意</button>
      <button class="btn btn-primary" bindtap="onAgree">同意</button>
    </view>
  </view>
</view>
